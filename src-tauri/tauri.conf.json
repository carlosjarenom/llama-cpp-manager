{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llama-manager",
  "version": "0.1.0",
  "identifier": "com.carlosjarenom.llama-manager",
  "build": {
    "frontendDist": "src",
    "beforeBuildCommand": "true",
    "beforeDevCommand": "true"
  },
  "app": {
    "windows": [
      {
        "title": "llama.cpp Model Manager",
        "width": 720,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 500,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true,
    "windowsManagement": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
